# ──────────────────────────────────────────────
# FISCOCONTROL — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ──────────────────────────────────────────────

# Banco de Dados PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://admin:senha_admin@localhost:5432/fiscocontrol"

# NextAuth
# Gere um secret com: openssl rand -base64 32
NEXTAUTH_SECRET="seu-secret-muito-seguro-aqui"
NEXTAUTH_URL="http://localhost:3000"

# Evolution API — WhatsApp (não oficial)
WHATSAPP_API_URL="http://localhost:8080"
WHATSAPP_API_KEY="fiscocontrol_secret_key"

# Opcional: Claude API (para Agente IA)
CLAUDE_API_KEY=""

# ──────────────────────────────────────────────
# Integra Contador Serpro API
# ──────────────────────────────────────────────
SERPRO_CONSUMER_KEY="sua-consumer-key-aqui"
SERPRO_CONSUMER_SECRET="seu-consumer-secret-aqui"
SERPRO_API_BASE_URL="https://gateway.apiserpro.serpro.gov.br/integra-contador/v1"
SERPRO_AUTH_URL="https://gateway.apiserpro.serpro.gov.br/token"
SERPRO_ECNPJ_PATH="/caminho/para/seu/certificado.pfx"
SERPRO_ECNPJ_PASSWORD="senha-do-certificado-aqui"
